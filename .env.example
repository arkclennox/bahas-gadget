# Supabase PostgreSQL — gunakan URL pooler (port 6543) untuk runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase direct connection (port 5432) — untuk prisma db push / migrate
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Password untuk admin dashboard (/admin)
ADMIN_SECRET="ganti-dengan-password-aman"

# URL publik website (digunakan untuk sitemap dan metadata)
NEXT_PUBLIC_SITE_URL="https://bahasgadget.com"
